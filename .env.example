# Redaction Lab — variables de entorno
# Ninguna de estas claves debe exponerse jamás al cliente salvo las prefijadas
# NEXT_PUBLIC_ (sección 15.6: "nunca expuestas al cliente"; sección 9.4: "las
# claves nunca deberán exponerse en el cliente").
# Este archivo es solo una plantilla — copiar a .env.local y completar valores reales.

# --- Base de datos (PostgreSQL 17 vía Supabase — resolución 18.1) ---
DATABASE_URL="postgresql://user:password@localhost:5432/redaction_lab"
DIRECT_URL="postgresql://user:password@localhost:5432/redaction_lab"
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# --- Autenticación (Clerk — resolución 18.1) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Proveedores de IA (sección 9.4, resolución 18.1: OpenAI + Anthropic activos, Gemini futuro) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY="" # reservado — Gemini no activo en el MVP (resolución 18.1)

# --- Caché (Redis — sección 15.1) ---
REDIS_URL="redis://localhost:6379"

# --- Observabilidad (sección 15.5/15.6) ---
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# --- Aplicación ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
